{
  "info": {
    "name": "Property Booking API - Complete Flow",
    "description": "Complete API testing flow with step-by-step guide",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "USER_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "ADMIN_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "PROPERTY_ID_1",
      "value": "",
      "type": "string"
    },
    {
      "key": "PROPERTY_ID_2",
      "value": "",
      "type": "string"
    },
    {
      "key": "BOOKING_ID",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. AUTH MODULE",
      "item": [
        {
          "name": "1.1 Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"USER_TOKEN\", jsonData.token);",
                  "    console.log(\"USER_TOKEN saved:\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a regular user. Token will be auto-saved to USER_TOKEN variable."
          }
        },
        {
          "name": "1.2 Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"ADMIN_TOKEN\", jsonData.token);",
                  "    console.log(\"ADMIN_TOKEN saved:\", jsonData.token);",
                  "    console.log(\"⚠️ IMPORTANT: Run 'node checkUser.js' to set admin role!\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register admin user. After this, run: node checkUser.js"
          }
        },
        {
          "name": "1.3 Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"USER_TOKEN\", jsonData.token);",
                  "    console.log(\"USER_TOKEN updated:\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as regular user"
          }
        },
        {
          "name": "1.4 Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"ADMIN_TOKEN\", jsonData.token);",
                  "    console.log(\"ADMIN_TOKEN updated:\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as admin. Run this AFTER setting admin role in DB."
          }
        }
      ]
    },
    {
      "name": "2. PROPERTY MODULE",
      "item": [
        {
          "name": "2.1 Create Property 1 (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"PROPERTY_ID_1\", jsonData.data._id);",
                  "    console.log(\"PROPERTY_ID_1 saved:\", jsonData.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Luxury Beach Villa\",\n  \"description\": \"Beautiful beachfront property with ocean views\",\n  \"location\": \"Miami Beach, FL\",\n  \"price\": 250,\n  \"amenities\": [\"WiFi\", \"Pool\", \"Beach Access\", \"Parking\"],\n  \"images\": [\"https://example.com/image1.jpg\"]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/properties",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "properties"]
            },
            "description": "Create first property (Admin only)"
          }
        },
        {
          "name": "2.2 Create Property 2 (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"PROPERTY_ID_2\", jsonData.data._id);",
                  "    console.log(\"PROPERTY_ID_2 saved:\", jsonData.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mountain Cabin Retreat\",\n  \"description\": \"Cozy cabin in the mountains\",\n  \"location\": \"Aspen, CO\",\n  \"price\": 180,\n  \"amenities\": [\"WiFi\", \"Fireplace\", \"Hiking Trails\"],\n  \"images\": [\"https://example.com/cabin.jpg\"]\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/properties",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "properties"]
            },
            "description": "Create second property (Admin only)"
          }
        },
        {
          "name": "2.3 Get All Properties (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/properties?page=1&limit=10",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "properties"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "location",
                  "value": "Miami",
                  "disabled": true
                },
                {
                  "key": "minPrice",
                  "value": "100",
                  "disabled": true
                },
                {
                  "key": "maxPrice",
                  "value": "300",
                  "disabled": true
                },
                {
                  "key": "sort",
                  "value": "price_asc",
                  "disabled": true
                }
              ]
            },
            "description": "Get all properties with optional filters (No auth required)"
          }
        },
        {
          "name": "2.4 Get Single Property (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/properties/{{PROPERTY_ID_1}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "properties", "{{PROPERTY_ID_1}}"]
            },
            "description": "Get single property by ID (No auth required)"
          }
        },
        {
          "name": "2.5 Update Property (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 300,\n  \"description\": \"Updated: Stunning beachfront villa with private pool\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/properties/{{PROPERTY_ID_1}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "properties", "{{PROPERTY_ID_1}}"]
            },
            "description": "Update property (Admin only)"
          }
        },
        {
          "name": "2.6 Delete Property (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/properties/{{PROPERTY_ID_2}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "properties", "{{PROPERTY_ID_2}}"]
            },
            "description": "Delete property (Admin only)"
          }
        }
      ]
    },
    {
      "name": "3. BOOKING MODULE",
      "item": [
        {
          "name": "3.1 Create Booking (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"BOOKING_ID\", jsonData.data._id);",
                  "    console.log(\"BOOKING_ID saved:\", jsonData.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"property\": \"{{PROPERTY_ID_1}}\",\n  \"checkIn\": \"2025-02-01\",\n  \"checkOut\": \"2025-02-05\",\n  \"guests\": 2\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/bookings",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "bookings"]
            },
            "description": "Create a booking (Authenticated user)"
          }
        },
        {
          "name": "3.2 Get My Bookings (User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/bookings/my-bookings",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "bookings", "my-bookings"]
            },
            "description": "Get all bookings for logged-in user"
          }
        },
        {
          "name": "3.3 Get Single Booking (User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/bookings/{{BOOKING_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "bookings", "{{BOOKING_ID}}"]
            },
            "description": "Get single booking by ID"
          }
        },
        {
          "name": "3.4 Update Booking Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ADMIN_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/bookings/{{BOOKING_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "bookings", "{{BOOKING_ID}}"]
            },
            "description": "Update booking status (Admin only). Status: pending, confirmed, cancelled"
          }
        },
        {
          "name": "3.5 Cancel Booking (User)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{USER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/bookings/{{BOOKING_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "bookings", "{{BOOKING_ID}}"]
            },
            "description": "Cancel booking (User or Admin)"
          }
        }
      ]
    }
  ]
}
